# The port Render runs the app on (Render sets this automatically, but for local use 5000)
PORT=5000

# Your PostgreSQL connection string (e.g., from Supabase)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT].supabase.co:5432/postgres

# Your secret key for signing JWTs
JWT_SECRET=super_secret_jwt_key_here

# The URL of your deployed frontend (e.g., from Vercel) to configure CORS
FRONTEND_URL=https://your-frontend-app.vercel.app
